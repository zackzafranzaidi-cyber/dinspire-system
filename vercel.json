{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "staff.dinspirebarbershop.com" }],
      "destination": "/staff/index.html"
    },
    {
      "source": "/manifest.json",
      "has": [{ "type": "host", "value": "staff.dinspirebarbershop.com" }],
      "destination": "/staff/manifest.json"
    },
    {
      "source": "/sw.js",
      "has": [{ "type": "host", "value": "staff.dinspirebarbershop.com" }],
      "destination": "/staff/sw.js"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "owner.dinspirebarbershop.com" }],
      "destination": "/owner/index.html"
    },
    {
      "source": "/manifest.json",
      "has": [{ "type": "host", "value": "owner.dinspirebarbershop.com" }],
      "destination": "/owner/manifest.json"
    },
    {
      "source": "/sw.js",
      "has": [{ "type": "host", "value": "owner.dinspirebarbershop.com" }],
      "destination": "/owner/sw.js"
    }
  ]
}
