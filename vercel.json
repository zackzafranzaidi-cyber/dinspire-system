{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(?!staff/)(.*)",
      "has": [
        {
          "type": "host",
          "value": "staff.dinspirebarbershop.com"
        }
      ],
      "destination": "/staff/$1"
    },
    {
      "source": "/(?!owner/)(.*)",
      "has": [
        {
          "type": "host",
          "value": "owner.dinspirebarbershop.com"
        }
      ],
      "destination": "/owner/$1"
    }
  ]
}
